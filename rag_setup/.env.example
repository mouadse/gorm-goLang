# Copy this file to .env and replace placeholders before running compose.

OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_MAX_TOKENS=512

# Optional Hugging Face token for higher model download rate limits.
HF_TOKEN=
HF_HUB_DISABLE_XET=1

QDRANT_COLLECTION=books
QDRANT_TIMEOUT_SECONDS=10
QDRANT_ASYNC_SCORER=true

RAG_QUERY_MODE=hybrid
RAG_SIMILARITY_TOP_K=8
RAG_SPARSE_TOP_K=8
RAG_SIMILARITY_CUTOFF=0.0
RAG_SEARCH_HNSW_EF=128
RAG_EXACT_SEARCH=0
RAG_INDEXED_ONLY=0
RAG_HYBRID_FUSION=rrf
RAG_HYBRID_ALPHA=0.5
RAG_HYBRID_RRF_K=60
RAG_QUANTIZATION_RESCORE=1
RAG_QUANTIZATION_IGNORE=0
RAG_QUANTIZATION_OVERSAMPLING=3.0
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_EMBED_DIMENSION=768
RAG_EMBED_LOCAL_ONLY=0
RAG_EMBED_BATCH_SIZE=64
RAG_EMBED_PARALLEL=0
RAG_CACHE_TTL_SECONDS=3600

QDRANT_SHARD_NUMBER=1
QDRANT_REPLICATION_FACTOR=1
QDRANT_WRITE_CONSISTENCY_FACTOR=1
QDRANT_ON_DISK_PAYLOAD=1
QDRANT_DENSE_ON_DISK=0
QDRANT_SPARSE_ON_DISK=0
QDRANT_HNSW_M=32
QDRANT_HNSW_EF_CONSTRUCT=200
QDRANT_FULL_SCAN_THRESHOLD=10000
QDRANT_MAX_INDEXING_THREADS=0
QDRANT_DEFAULT_SEGMENT_NUMBER=2
QDRANT_INDEXING_THRESHOLD=10000
QDRANT_FLUSH_INTERVAL_SEC=5
QDRANT_PREVENT_UNOPTIMIZED=0
QDRANT_ENABLE_QUANTIZATION=1
QDRANT_QUANTIZATION_ALWAYS_RAM=1
